{
  "name": "project-agap",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "validate": "pnpm check-types && pnpm build && pnpm test:native",
    "lint": "turbo lint",
    "test:native": "node packages/api/node_modules/vitest/vitest.mjs run --config packages/api/vitest.config.ts",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @project-agap/db db:push",
    "db:studio": "turbo -F @project-agap/db db:studio",
    "db:generate": "turbo -F @project-agap/db db:generate",
    "db:migrate": "turbo -F @project-agap/db db:migrate",
    "supabase:start": "pnpm dlx supabase start --workdir packages/db",
    "supabase:stop": "pnpm dlx supabase stop --workdir packages/db",
    "supabase:status": "pnpm dlx supabase status --workdir packages/db",
    "supabase:migration:new": "pnpm dlx supabase migration new --workdir packages/db"
  },  
  "dependencies": {
    "@project-agap/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@project-agap/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    }
  }
}
