EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_APP_ENV=development

# For physical-device testing, use your laptop's LAN IP instead of localhost.
EXPO_PUBLIC_SERVER_URL=http://192.168.1.47:3001

# Google Maps API Key for directions (get from: https://console.cloud.google.com/google/maps-apis/credentials)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Optional offline tile pack for react-native-maps LocalTile.
# Example Android template: /data/user/0/your.app.id/files/tiles/{z}/{x}/{y}.png
EXPO_PUBLIC_OFFLINE_TILE_TEMPLATE=
EXPO_PUBLIC_OFFLINE_TILE_PACK_LABEL=Barangay base map
EXPO_PUBLIC_OFFLINE_TILE_PACK_VERSION=
EXPO_PUBLIC_OFFLINE_TILE_SIZE=256
