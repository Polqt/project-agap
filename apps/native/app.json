{
  "expo": {
    "version": "1.0.0",
    "scheme": "project-agap",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Kailangan ng Agap ang camera para sa pag-scan ng QR check-in sa evacuation center."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kailangan ng Agap ang lokasyon mo para mahanap ang pinakamalapit na evacuation center at makapagpadala ng status ping."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A56C4"
        }
      ],
      "expo-secure-store",
      "expo-sqlite"
    ],
    "web": {
      "bundler": "metro"
    },
    "name": "project-agap",
    "slug": "project-agap",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.projectagap.mobile",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "19205e34-a713-4c7f-8950-8c84844e63f4"
      }
    },
    "owner": "jepoy001"
  }
}
