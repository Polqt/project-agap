{
  "name": "@project-agap/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:push": "pnpm dlx supabase db push --workdir .",
    "db:generate": "drizzle-kit generate",
    "db:studio": "pnpm dlx supabase studio --workdir .",
    "db:migrate": "pnpm dlx supabase migration up --workdir ."
  },
  "dependencies": {
    "@project-agap/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@project-agap/config": "workspace:*",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "catalog:"
  }
}
